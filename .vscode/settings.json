{
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "pyproject.toml": "uv.lock",
    ".env.example": ".env, .env.*",
    "README.md": "LICENSE, CHANGELOG.md"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/*.egg-info": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/uv.lock": true,
    ".pre-commit-config.yaml": true,
    ".openapi-python-client.yaml": true,
    "biome.json": true,
    "orval.config.ts": true,
    "**/tsconfig*.json": true,
    "**/vite.config.*": true
  },
  "search.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/*.egg-info": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/uv.lock": true,
    ".pre-commit-config.yaml": true,
    ".openapi-python-client.yaml": true,
    "biome.json": true,
    "orval.config.ts": true,
    "**/tsconfig*.json": true,
    "**/vite.config.*": true
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.analysis.extraPaths": [
    "${workspaceFolder}/apps/api/src",
    "${workspaceFolder}/apps/tui/src",
    "${workspaceFolder}/packages/client-py"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["apps/api/tests"]
}
