{
  "openapi": "3.1.0",
  "info": {
    "title": "Logos API",
    "version": "0.1.0"
  },
  "paths": {
    "/ai/models": {
      "get": {
        "tags": ["ai"],
        "summary": "List Ai Models",
        "operationId": "listAIModels",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/AIModelRead"
                  },
                  "type": "array",
                  "title": "Response Listaimodels"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health Check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          }
        }
      }
    },
    "/session-configs/default": {
      "get": {
        "tags": ["session-configs"],
        "summary": "Get Default Session Config",
        "operationId": "getDefaultSessionConfig",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionConfigRead"
                }
              }
            }
          }
        }
      }
    },
    "/session-configs/{config_id}": {
      "get": {
        "tags": ["session-configs"],
        "summary": "Get Session Config",
        "operationId": "getSessionConfig",
        "parameters": [
          {
            "name": "config_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Config Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionConfigRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions": {
      "get": {
        "tags": ["sessions"],
        "summary": "List Sessions",
        "operationId": "listSessions",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SessionSummaryRead"
                  },
                  "type": "array",
                  "title": "Response Listsessions"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["sessions"],
        "summary": "Create Session",
        "operationId": "createSession",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}": {
      "get": {
        "tags": ["sessions"],
        "summary": "Get Session",
        "operationId": "getSession",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/export": {
      "post": {
        "tags": ["sessions"],
        "summary": "Export Session",
        "operationId": "exportSession",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionExportResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/events": {
      "get": {
        "tags": ["sessions"],
        "summary": "List Session Events",
        "operationId": "listSessionEvents",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EventRead"
                  },
                  "title": "Response Listsessionevents"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/events/stream": {
      "get": {
        "tags": ["sessions"],
        "summary": "Stream Session Events",
        "operationId": "streamSessionEvents",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          },
          {
            "name": "after_event_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "title": "After Event Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/tokens/stream": {
      "get": {
        "tags": ["sessions"],
        "summary": "Stream Session Tokens",
        "operationId": "streamSessionTokens",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          },
          {
            "name": "stream_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Stream Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AIModelRead": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "provider": {
            "$ref": "#/components/schemas/AIProviderName"
          },
          "supports_reasoning": {
            "type": "boolean",
            "title": "Supports Reasoning"
          }
        },
        "type": "object",
        "required": ["id", "label", "provider", "supports_reasoning"],
        "title": "AIModelRead"
      },
      "AIProviderName": {
        "type": "string",
        "enum": ["openai", "anthropic", "gemini", "deepseek"],
        "title": "AIProviderName"
      },
      "AgentParticipantCreate": {
        "properties": {
          "type": {
            "type": "string",
            "const": "agent",
            "title": "Agent",
            "description": "AI participant that responds with the selected model and system prompt.",
            "default": "agent"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "title": "Name",
            "description": "Display name for this participant."
          },
          "model": {
            "type": "string",
            "minLength": 1,
            "title": "Model",
            "description": "AI model used to generate this participant's responses."
          },
          "system_prompt": {
            "type": "string",
            "minLength": 1,
            "title": "System prompt",
            "description": "Instructions that shape how this participant behaves."
          },
          "reasoning_effort": {
            "$ref": "#/components/schemas/ReasoningEffort",
            "title": "Reasoning effort",
            "description": "Model reasoning effort used for this participant's responses."
          }
        },
        "type": "object",
        "required": ["name", "model", "system_prompt", "reasoning_effort"],
        "title": "AgentParticipantCreate"
      },
      "AgentParticipantRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "type": {
            "type": "string",
            "const": "agent",
            "title": "Type",
            "default": "agent"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "system_prompt": {
            "type": "string",
            "title": "System Prompt"
          },
          "reasoning_effort": {
            "$ref": "#/components/schemas/ReasoningEffort"
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "created_at",
          "updated_at",
          "model",
          "system_prompt",
          "reasoning_effort"
        ],
        "title": "AgentParticipantRead"
      },
      "DebateRoundCompletedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "debate_round.completed",
            "title": "Type"
          }
        },
        "type": "object",
        "required": ["id", "session_id", "created_at", "updated_at", "type"],
        "title": "DebateRoundCompletedEventRead"
      },
      "DebateRoundStartedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "debate_round.started",
            "title": "Type"
          },
          "round_number": {
            "type": "integer",
            "title": "Round Number"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "round_number"
        ],
        "title": "DebateRoundStartedEventRead"
      },
      "EventRead": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/SessionStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/SessionCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/ProposalStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/ProposalCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/DebateRoundStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/DebateRoundCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/ResolutionStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/ResolutionCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/MessageStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/MessageCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/ReasoningStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/ReasoningCompletedEventRead"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "debate_round.completed": "#/components/schemas/DebateRoundCompletedEventRead",
            "debate_round.started": "#/components/schemas/DebateRoundStartedEventRead",
            "message.completed": "#/components/schemas/MessageCompletedEventRead",
            "message.started": "#/components/schemas/MessageStartedEventRead",
            "proposal.completed": "#/components/schemas/ProposalCompletedEventRead",
            "proposal.started": "#/components/schemas/ProposalStartedEventRead",
            "reasoning.completed": "#/components/schemas/ReasoningCompletedEventRead",
            "reasoning.started": "#/components/schemas/ReasoningStartedEventRead",
            "resolution.completed": "#/components/schemas/ResolutionCompletedEventRead",
            "resolution.started": "#/components/schemas/ResolutionStartedEventRead",
            "session.completed": "#/components/schemas/SessionCompletedEventRead",
            "session.started": "#/components/schemas/SessionStartedEventRead"
          }
        }
      },
      "FullHistoryConfigCreate": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "full",
            "title": "Full transcript",
            "description": "Include the full session transcript when generating the next response.",
            "default": "full"
          }
        },
        "type": "object",
        "title": "FullHistoryConfigCreate"
      },
      "FullHistoryConfigRead": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "full",
            "title": "Full transcript",
            "description": "Include the full session transcript when generating the next response.",
            "default": "full"
          }
        },
        "type": "object",
        "title": "FullHistoryConfigRead"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthCheckResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": ["status"],
        "title": "HealthCheckResponse"
      },
      "HistoryConfigCreate": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FullHistoryConfigCreate"
          },
          {
            "$ref": "#/components/schemas/SlidingWindowHistoryConfigCreate"
          }
        ],
        "discriminator": {
          "propertyName": "mode",
          "mapping": {
            "full": "#/components/schemas/FullHistoryConfigCreate",
            "sliding_window": "#/components/schemas/SlidingWindowHistoryConfigCreate"
          }
        }
      },
      "HistoryConfigRead": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/FullHistoryConfigRead"
          },
          {
            "$ref": "#/components/schemas/SlidingWindowHistoryConfigRead"
          }
        ],
        "discriminator": {
          "propertyName": "mode",
          "mapping": {
            "full": "#/components/schemas/FullHistoryConfigRead",
            "sliding_window": "#/components/schemas/SlidingWindowHistoryConfigRead"
          }
        }
      },
      "JudgeResolutionConfigCreate": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "judge_llm",
            "title": "Judge LLM",
            "description": "Use an AI judge to select the final resolution.",
            "default": "judge_llm"
          },
          "judge_model": {
            "type": "string",
            "minLength": 1,
            "title": "Judge model",
            "description": "Model used by the AI judge to choose the final resolution."
          },
          "judge_temperature": {
            "type": "number",
            "title": "Judge temperature",
            "description": "Sampling temperature used by the AI judge."
          }
        },
        "type": "object",
        "required": ["judge_model", "judge_temperature"],
        "title": "JudgeResolutionConfigCreate"
      },
      "JudgeResolutionConfigRead": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "judge_llm",
            "title": "Judge LLM",
            "description": "Use an AI judge to select the final resolution.",
            "default": "judge_llm"
          },
          "judge_model": {
            "type": "string",
            "minLength": 1,
            "title": "Judge model",
            "description": "Model used by the AI judge to choose the final resolution."
          },
          "judge_temperature": {
            "type": "number",
            "title": "Judge temperature",
            "description": "Sampling temperature used by the AI judge."
          }
        },
        "type": "object",
        "required": ["judge_model", "judge_temperature"],
        "title": "JudgeResolutionConfigRead"
      },
      "MessageCompletedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "message.completed",
            "title": "Type"
          },
          "message_id": {
            "type": "string",
            "format": "uuid",
            "title": "Message Id"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "message_id",
          "content"
        ],
        "title": "MessageCompletedEventRead"
      },
      "MessageStartedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "message.started",
            "title": "Type"
          },
          "message_id": {
            "type": "string",
            "format": "uuid",
            "title": "Message Id"
          },
          "sender": {
            "$ref": "#/components/schemas/ParticipantRead"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "message_id",
          "sender"
        ],
        "title": "MessageStartedEventRead"
      },
      "NoneResolutionConfigCreate": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "none",
            "title": "No automatic resolution",
            "description": "Do not select a final resolution automatically.",
            "default": "none"
          }
        },
        "type": "object",
        "title": "NoneResolutionConfigCreate"
      },
      "NoneResolutionConfigRead": {
        "properties": {
          "mode": {
            "type": "string",
            "const": "none",
            "title": "No automatic resolution",
            "description": "Do not select a final resolution automatically.",
            "default": "none"
          }
        },
        "type": "object",
        "title": "NoneResolutionConfigRead"
      },
      "ParticipantCreate": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/AgentParticipantCreate"
          },
          {
            "$ref": "#/components/schemas/UserParticipantCreate"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "agent": "#/components/schemas/AgentParticipantCreate",
            "user": "#/components/schemas/UserParticipantCreate"
          }
        }
      },
      "ParticipantRead": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/AgentParticipantRead"
          },
          {
            "$ref": "#/components/schemas/UserParticipantRead"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "agent": "#/components/schemas/AgentParticipantRead",
            "user": "#/components/schemas/UserParticipantRead"
          }
        }
      },
      "ProposalCompletedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "proposal.completed",
            "title": "Type"
          }
        },
        "type": "object",
        "required": ["id", "session_id", "created_at", "updated_at", "type"],
        "title": "ProposalCompletedEventRead"
      },
      "ProposalStartedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
