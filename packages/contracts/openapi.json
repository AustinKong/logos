{
  "openapi": "3.1.0",
  "info": {
    "title": "Logos API",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Health Check",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthCheckResponse"
                }
              }
            }
          }
        }
      }
    },
    "/sessions": {
      "post": {
        "tags": ["sessions"],
        "summary": "Create Session",
        "operationId": "createSession",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SessionCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}": {
      "get": {
        "tags": ["sessions"],
        "summary": "Get Session",
        "operationId": "getSession",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionRead"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/events": {
      "get": {
        "tags": ["sessions"],
        "summary": "List Session Events",
        "operationId": "listSessionEvents",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/EventRead"
                  },
                  "title": "Response Listsessionevents"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/run-until-blocked": {
      "post": {
        "tags": ["sessions"],
        "summary": "Run Session Until Blocked",
        "operationId": "runSessionUntilBlocked",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Successful Response"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/events/stream": {
      "get": {
        "tags": ["sessions"],
        "summary": "Stream Session Events",
        "operationId": "streamSessionEvents",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          },
          {
            "name": "after_event_id",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "uuid"
                },
                {
                  "type": "null"
                }
              ],
              "title": "After Event Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sessions/{session_id}/tokens/stream": {
      "get": {
        "tags": ["sessions"],
        "summary": "Stream Session Tokens",
        "operationId": "streamSessionTokens",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Session Id"
            }
          },
          {
            "name": "stream_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Stream Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentParticipantCreate": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "model": {
            "type": "string",
            "title": "Model"
          },
          "system_prompt": {
            "type": "string",
            "title": "System Prompt"
          }
        },
        "type": "object",
        "required": ["name", "model", "system_prompt"],
        "title": "AgentParticipantCreate"
      },
      "EventRead": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/SessionStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/SessionCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/MessageStartedEventRead"
          },
          {
            "$ref": "#/components/schemas/MessageCompletedEventRead"
          },
          {
            "$ref": "#/components/schemas/ParticipantVoteEventRead"
          },
          {
            "$ref": "#/components/schemas/ParticipantRemovedEventRead"
          },
          {
            "$ref": "#/components/schemas/ResolutionCreatedEventRead"
          }
        ],
        "discriminator": {
          "propertyName": "type",
          "mapping": {
            "message.completed": "#/components/schemas/MessageCompletedEventRead",
            "message.started": "#/components/schemas/MessageStartedEventRead",
            "participant.removed": "#/components/schemas/ParticipantRemovedEventRead",
            "participant.vote": "#/components/schemas/ParticipantVoteEventRead",
            "resolution.created": "#/components/schemas/ResolutionCreatedEventRead",
            "session.completed": "#/components/schemas/SessionCompletedEventRead",
            "session.started": "#/components/schemas/SessionStartedEventRead"
          }
        }
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthCheckResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": ["status"],
        "title": "HealthCheckResponse"
      },
      "MessageCompletedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "message.completed",
            "title": "Type"
          },
          "message_id": {
            "type": "string",
            "format": "uuid",
            "title": "Message Id"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "message_id",
          "content"
        ],
        "title": "MessageCompletedEventRead"
      },
      "MessageStartedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "message.started",
            "title": "Type"
          },
          "message_id": {
            "type": "string",
            "format": "uuid",
            "title": "Message Id"
          },
          "sender": {
            "$ref": "#/components/schemas/ParticipantRead"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "message_id",
          "sender"
        ],
        "title": "MessageStartedEventRead"
      },
      "ParticipantRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "type": {
            "$ref": "#/components/schemas/ParticipantType"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          }
        },
        "type": "object",
        "required": ["id", "type", "name", "created_at", "updated_at"],
        "title": "ParticipantRead"
      },
      "ParticipantRemovedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "participant.removed",
            "title": "Type"
          },
          "removed": {
            "$ref": "#/components/schemas/ParticipantRead"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "removed"
        ],
        "title": "ParticipantRemovedEventRead"
      },
      "ParticipantType": {
        "type": "string",
        "enum": ["agent", "user", "system"],
        "title": "ParticipantType"
      },
      "ParticipantVoteEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "participant.vote",
            "title": "Type"
          },
          "voter": {
            "$ref": "#/components/schemas/ParticipantRead"
          },
          "target": {
            "$ref": "#/components/schemas/ParticipantRead"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "voter",
          "target",
          "reason"
        ],
        "title": "ParticipantVoteEventRead"
      },
      "ResolutionCreatedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "resolution.created",
            "title": "Type"
          },
          "resolution": {
            "type": "string",
            "title": "Resolution"
          }
        },
        "type": "object",
        "required": [
          "id",
          "session_id",
          "created_at",
          "updated_at",
          "type",
          "resolution"
        ],
        "title": "ResolutionCreatedEventRead"
      },
      "SessionCompletedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "session.completed",
            "title": "Type"
          }
        },
        "type": "object",
        "required": ["id", "session_id", "created_at", "updated_at", "type"],
        "title": "SessionCompletedEventRead"
      },
      "SessionCreate": {
        "properties": {
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "agents": {
            "items": {
              "$ref": "#/components/schemas/AgentParticipantCreate"
            },
            "type": "array",
            "title": "Agents"
          }
        },
        "type": "object",
        "required": ["prompt"],
        "title": "SessionCreate"
      },
      "SessionRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "participants": {
            "items": {
              "$ref": "#/components/schemas/ParticipantRead"
            },
            "type": "array",
            "title": "Participants"
          }
        },
        "type": "object",
        "required": [
          "id",
          "prompt",
          "created_at",
          "updated_at",
          "participants"
        ],
        "title": "SessionRead"
      },
      "SessionStartedEventRead": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "session_id": {
            "type": "string",
            "format": "uuid",
            "title": "Session Id"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At"
          },
          "type": {
            "type": "string",
            "const": "session.started",
            "title": "Type"
          }
        },
        "type": "object",
        "required": ["id", "session_id", "created_at", "updated_at", "type"],
        "title": "SessionStartedEventRead"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
}
